---
import { SITE, AREAS, SERVICES, orgNode, websiteNode } from "../lib/site.js";
const { title, description, path = "/", schema = [] } = Astro.props;
const canonical = SITE.domain + path;
const allSchema = [orgNode(), websiteNode(), ...schema];
const tel = "tel:" + SITE.phoneTel;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE.brand} />
<meta property="og:image" content={SITE.domain + "/images/hero-home.webp"} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="theme-color" content="#15181D" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Schibsted+Grotesk:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
<script type="application/ld+json" set:html={JSON.stringify(allSchema)} />
<slot name="head" />
</head>
<body>

<svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
<symbol id="i-phone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></symbol>
<symbol id="i-car" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l1.5-4.5A2 2 0 0 1 8.4 7h7.2a2 2 0 0 1 1.9 1.5L19 13"/><path d="M3 17v-2a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2a1 1 0 0 1-1 1h-1"/><circle cx="7.5" cy="17.5" r="1.6"/><circle cx="16.5" cy="17.5" r="1.6"/></symbol>
<symbol id="i-van" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16V7a1 1 0 0 1 1-1h11l5 5v5"/><path d="M2 16h2m13 0h3"/><circle cx="7" cy="17.5" r="1.6"/><circle cx="17" cy="17.5" r="1.6"/><path d="M14 6v5h5"/></symbol>
<symbol id="i-flatbed" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 17h20"/><path d="M3 17l4-7h6l4 4h4"/><circle cx="7" cy="19" r="1.8"/><circle cx="17" cy="19" r="1.8"/></symbol>
<symbol id="i-bike" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.5" cy="16.5" r="3.2"/><circle cx="18.5" cy="16.5" r="3.2"/><path d="M5.5 16.5 9 9h4l2 3h3"/><path d="M9 9l-1-2"/></symbol>
<symbol id="i-truck" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17V7h10v10"/><path d="M13 11h4l3 3v3"/><circle cx="7" cy="17.5" r="1.8"/><circle cx="17" cy="17.5" r="1.8"/></symbol>
<symbol id="i-hook" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6"/><path d="M12 9a4 4 0 1 0 4 4"/><circle cx="12" cy="3" r="1"/></symbol>
<symbol id="i-bolt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7z"/></symbol>
<symbol id="i-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></symbol>
<symbol id="i-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></symbol>
<symbol id="i-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></symbol>
<symbol id="i-key" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="4.5"/><path d="m10.7 12.3 8.3-8.3M16 5l3 3M14 7l3 3"/></symbol>
<symbol id="i-fuel" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v18"/><path d="M3 14h10"/><path d="M13 9h2a2 2 0 0 1 2 2v6a2 2 0 0 0 2 2 2 2 0 0 0 2-2V8l-3-3"/></symbol>
<symbol id="i-battery" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="10" rx="2"/><path d="M22 11v2"/><path d="M7 10v4M11 10v4"/></symbol>
<symbol id="i-crash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 2 6 5-3-3 5 6 2-6 2 3 5-5-3-2 6-2-6-5 3 3-5-6-2 6-2-3-5 5 3z"/></symbol>
<symbol id="i-wrench" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5z"/></symbol>
<symbol id="i-route" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="2.5"/><circle cx="18" cy="5" r="2.5"/><path d="M8.5 19H14a3 3 0 0 0 0-6h-4a3 3 0 0 1 0-6h5.5"/></symbol>
<symbol id="i-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></symbol>
<symbol id="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></symbol>
<symbol id="i-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></symbol>
<symbol id="i-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></symbol>
<symbol id="i-mail" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></symbol>
</defs></svg>

<div class="utilbar"><div class="wrap">
  <span class="util-live"><span class="dot"></span> 24/7 Wrecker Dispatch · Grand Prairie, TX</span>
  <a href={tel} class="util-call"><svg><use href="#i-phone"/></svg> {SITE.phoneDisplay}</a>
</div></div>

<header class="site-header"><nav class="nav wrap">
  <a href="/" class="brand" aria-label="Grand Prairie Tow Truck home">
    <span class="mark" aria-hidden="true">
      <svg viewBox="0 0 44 44"><rect x="3" y="3" width="38" height="38" rx="10" fill="#D72631"/><path d="M22 12v8" stroke="#16181C" stroke-width="3.2" stroke-linecap="round"/><path d="M22 20a4.6 4.6 0 1 0 4.6 4.6" fill="none" stroke="#16181C" stroke-width="3.2" stroke-linecap="round"/><circle cx="22" cy="11.4" r="2.4" fill="#EFEDE7"/></svg>
    </span>
    <span class="bname">Grand Prairie Tow Truck<small>24/7 wrecker dispatch</small></span>
  </a>
  <button class="menu-toggle" aria-label="Open menu" onclick="document.getElementById('nav').classList.toggle('open')"><svg><use href="#i-menu"/></svg></button>
  <div class="nav-links" id="nav">
    <button class="nav-close" aria-label="Close menu" onclick="document.getElementById('nav').classList.remove('open')"><svg><use href="#i-x"/></svg></button>
    <a href="/">Home</a>
    <div class="has-sub" tabindex="0"><span class="sub-toggle" onclick="this.parentElement.classList.toggle('open')">Services ▾</span>
      <div class="submenu"><a href="/services/">All Services</a>{SERVICES.map((s) => <a href={s.url}>{s.name}</a>)}</div>
    </div>
    <div class="has-sub" tabindex="0"><span class="sub-toggle" onclick="this.parentElement.classList.toggle('open')">Areas ▾</span>
      <div class="submenu">{AREAS.map((a) => <a href={a.url}>{a.name}, TX</a>)}</div>
    </div>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
    <a class="nav-call" href={tel}><svg><use href="#i-phone"/></svg> {SITE.phoneDisplay}</a>
  </div>
</nav></header>

<main><slot /></main>

<footer class="site-footer"><div class="wrap">
  <div class="foot-grid">
    <div class="foot-brand">
      <div class="brand">
        <span class="mark" aria-hidden="true"><svg viewBox="0 0 44 44"><rect x="3" y="3" width="38" height="38" rx="10" fill="#D72631"/><path d="M22 12v8" stroke="#0F1114" stroke-width="3.2" stroke-linecap="round"/><path d="M22 20a4.6 4.6 0 1 0 4.6 4.6" fill="none" stroke="#0F1114" stroke-width="3.2" stroke-linecap="round"/><circle cx="22" cy="11.4" r="2.4" fill="#EFEDE7"/></svg></span>
        <span class="bname">Grand Prairie Tow Truck<small>24/7 wrecker dispatch</small></span>
      </div>
      <p>Fast, local towing and roadside help across Grand Prairie, TX and the surrounding 75050, 75051, and 75052 area. One call puts the right truck on the way.</p>
      <a class="foot-call" href={tel}><svg><use href="#i-phone"/></svg> {SITE.phoneDisplay}</a>
    </div>
    <div><h4>Services</h4><ul>{SERVICES.map((s) => <li><a href={s.url}>{s.name}</a></li>)}<li><a href="/services/">All Services</a></li></ul></div>
    <div><h4>Areas</h4><ul>{AREAS.map((a) => <li><a href={a.url}>{a.name}, TX</a></li>)}</ul></div>
    <div><h4>Company</h4><ul>
      <li><a href="/about/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
      <li><a href="/blog/">Blog</a></li>
      <li><a href="/privacy-policy/">Privacy Policy</a></li>
    </ul>
      <p class="mono-tiny" style="margin-top:14px">Open 24 hours · 7 days</p>
      <a class="mono-tiny foot-mail" href={"mailto:" + SITE.email}><svg><use href="#i-mail"/></svg> {SITE.email}</a>
    </div>
  </div>
  <div class="foot-bottom">
    <p class="disclaimer">Grand Prairie Tow Truck is a free service to assist drivers in connecting with local service providers. All contractors/providers are independent and Grand Prairie Tow Truck does not warrant or guarantee any work performed. It is the responsibility of the customer to verify that the hired provider furnishes the necessary license and insurance required for the work being performed. All persons depicted in a photo or video are actors or models and not contractors listed on Grand Prairie Tow Truck.</p>
    <p class="copyright">© 2026 Grand Prairie Tow Truck. Serving Grand Prairie, TX and the 75050 / 75051 / 75052 area. Arrival times are estimates and vary with traffic, weather, and demand.</p>
  </div>
</div></footer>

<a class="mobile-call" href={tel}><svg><use href="#i-phone"/></svg> Tap to Call · 24/7 Dispatch</a>
</body>
</html>
