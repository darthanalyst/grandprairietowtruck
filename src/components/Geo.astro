---
import Base from "../layouts/Base.astro";
import { SITE, SERVICES, serviceNode, breadcrumb, faqNode } from "../lib/site.js";
const {
  city, slug, title, description, lead, heroImg = "/images/hero-geo.webp",
  intro = [], roadsHeading = "Roads & areas we cover", roads = [],
  whyHeading, why = [], faqs = [],
} = Astro.props;
const tel = "tel:" + SITE.phoneTel;
const heroAlt = `Tow truck serving ${city}, TX, 24/7 towing and roadside assistance`;
const schema = [
  serviceNode({ name: `Towing in ${city}, TX`, serviceType: "Towing", description, url: slug, cities: [city] }),
  breadcrumb([{ name: "Home", url: "/" }, { name: `${city}, TX`, url: slug }]),
];
if (faqs.length) schema.push(faqNode(faqs));
const featured = SERVICES.filter((s) => s.klass !== "Long-Haul");
---
<Base title={title} description={description} path={slug} schema={schema}>
  <div class="wrap"><nav class="crumbs"><a href="/">Home</a> / {city}, TX</nav></div>

  <section class="hero solo">
    <img class="hero-img" src={heroImg} alt={heroAlt} width="1600" height="900" loading="eager" decoding="async" />
    <span class="hero-scrim" aria-hidden="true"></span>
    <div class="wrap">
    <span class="eyebrow"><span class="dot"></span> 24/7 dispatch · {city}, TX</span>
    <h1>Towing in {city}, <em>TX</em></h1>
    <p class="lead">{lead}</p>
    <div class="cta-row">
      <a class="btn btn-call btn-lg" href={tel}><svg><use href="#i-phone"/></svg> Call {SITE.phoneDisplay}</a>
      <a class="btn btn-ghost btn-lg" href="#svc">See services</a>
    </div>
    <div class="chips">
      <span class="chip"><svg><use href="#i-clock"/></svg> Open 24/7</span>
      <span class="chip"><svg><use href="#i-bolt"/></svg> Fast local response</span>
      <span class="chip"><svg><use href="#i-shield"/></svg> Licensed &amp; insured</span>
    </div>
  </div></section>

  <div class="readout"><div class="wrap">
    <div class="read-cell"><span class="k">Dispatch</span><span class="v"><em>24/7</em></span></div>
    <div class="read-cell"><span class="k">Serving</span><span class="v">{city}, TX</span></div>
    <div class="read-cell"><span class="k">Trucks</span><span class="v">Light–Heavy</span></div>
    <div class="read-cell"><span class="k">Pricing</span><span class="v">Upfront</span></div>
  </div></div>

  <section><div class="wrap narrow">
    <div class="section-head"><span class="eyebrow">24/7 towing in {city}</span><h2>{`Local Towing & Roadside Help in ${city}`}</h2></div>
    <div class="prose">{intro.map((p) => <p set:html={p} />)}</div>
  </div></section>

  <section class="bg-paper2" id="svc"><div class="wrap">
    <div class="section-head"><span class="eyebrow">Services in {city}</span><h2>{`What We Bring to ${city}`}</h2></div>
    <div class="fleet">
      {featured.map((s) => (
        <a class="svc-card" href={s.url}>
          <div class="svc-top"><span class="svc-ic"><svg><use href={"#" + s.icon}/></svg></span><span class="svc-tag">{s.klass}</span></div>
          <h3>{s.name}</h3><p>{s.blurb}</p>
          <span class="more">View service <svg><use href="#i-arrow"/></svg></span>
        </a>
      ))}
    </div>
  </div></section>

  {roads.length > 0 && (
    <section><div class="wrap narrow">
      <div class="section-head"><h2>{roadsHeading}</h2></div>
      <div class="chips">{roads.map((r) => <span class="chip"><svg><use href="#i-route"/></svg> {r}</span>)}</div>
    </div></section>
  )}

  {why.length > 0 && (
    <section class="bg-paper2"><div class="wrap narrow">
      <div class="section-head"><h2>{whyHeading}</h2></div>
      <div class="prose">{why.map((p) => <p set:html={p} />)}</div>
    </div></section>
  )}

  {faqs.length > 0 && (
    <section><div class="wrap narrow">
      <div class="section-head"><span class="eyebrow">FAQ</span><h2>{`${city} Towing Questions`}</h2></div>
      <div class="faq">{faqs.map((f, i) => (
        <details open={i === 0}><summary>{f.q}</summary><div class="ans"><p set:html={f.a} /></div></details>
      ))}</div>
    </div></section>
  )}

  <section class="callband"><div class="wrap">
    <h2>{`Need a Tow in ${city}? Call Now.`}</h2>
    <div class="num"><a href={tel}>{SITE.phoneDisplay}</a></div>
    <p>Open 24 hours · Serving {city}, TX &amp; the Grand Prairie area</p>
    <div style="margin-top:18px"><a class="btn btn-call btn-lg" href={tel}><svg><use href="#i-phone"/></svg> Call Now</a></div>
  </div></section>
</Base>
